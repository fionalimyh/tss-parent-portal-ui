# TSS Parent Portal — Environment Variables
# Fill in real values below. NEVER commit the real `.env` file.

# Supabase
# Found in: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key — server-side only. NEVER expose to the browser or client components.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# WATI (WhatsApp Business API)
# Found in: WATI Dashboard -> API
WATI_API_ENDPOINT=https://live-mt-server.wati.io/your-account-id
WATI_API_KEY=your-wati-api-key-here

# Admin Access
# Comma-separated list of email addresses allowed to access /admin/* routes
ADMIN_EMAILS=admin@example.com
